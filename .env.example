# Optional local config overrides. Local Docker secrets default to committed
# development-only files under docker/secrets/dev/.

# Shared non-secret config
DBT_TARGET=local_pg
AWS_REGION=us-east-1
OLIST_AIRFLOW_RETRIES=2
OLIST_AIRFLOW_RETRY_DELAY_SECONDS=300
AIRFLOW_STATSD_ON=false
OLIST_S3_PREFIX=olist
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=olist
CLICKHOUSE_DATABASE=analytics
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST_PORT=19000
CLICKHOUSE_SECURE=false
CONTROL_POSTGRES_HOST=localhost
CONTROL_POSTGRES_PORT=5432
CONTROL_POSTGRES_DB=olist_control
CONTROL_POSTGRES_USER=olist_control
OLTP_POSTGRES_HOST=localhost
OLTP_POSTGRES_PORT=5433
OLTP_POSTGRES_DB=olist_oltp
OLTP_POSTGRES_USER=olist_simulator
KAFKA_HOST_PORT=9092
KAFKA_CONNECT_HOST_PORT=8083
APICURIO_HOST_PORT=8081
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
NIFI_HOST_PORT=8443
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_HOST_PORT=9093
GRAFANA_HOST_PORT=3000
LOKI_HOST_PORT=3100

# Optional AWS / Redshift runtime config for the AWS DAG.
# Use standard AWS authentication resolution (IAM role, SSO, shared config, or
# a short-lived local session). Avoid storing static AWS keys in this file.
OLIST_S3_BUCKET=
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=

# Optional: point Docker Compose to different local secret files without
# editing compose.yaml.
# POSTGRES_PASSWORD_SOURCE_FILE=.secrets/postgres_password.txt
# CLICKHOUSE_PASSWORD_SOURCE_FILE=.secrets/clickhouse_password.txt
# AIRFLOW_POSTGRES_PASSWORD_SOURCE_FILE=.secrets/airflow_postgres_password.txt
# CONTROL_POSTGRES_PASSWORD_SOURCE_FILE=.secrets/control_postgres_password.txt
# AIRFLOW_API_SECRET_KEY_SOURCE_FILE=.secrets/airflow_api_secret_key.txt
# REDSHIFT_PASSWORD_SOURCE_FILE=.secrets/redshift_password.txt
# OLTP_ADMIN_PASSWORD_SOURCE_FILE=.secrets/oltp_admin_password.txt
# OLTP_SIMULATOR_PASSWORD_SOURCE_FILE=.secrets/oltp_simulator_password.txt
# OLTP_CDC_READER_PASSWORD_SOURCE_FILE=.secrets/oltp_cdc_reader_password.txt
# MINIO_ROOT_PASSWORD_SOURCE_FILE=.secrets/minio_root_password.txt
# MINIO_NIFI_PASSWORD_SOURCE_FILE=.secrets/minio_nifi_password.txt
# MINIO_CDC_LOADER_PASSWORD_SOURCE_FILE=.secrets/minio_cdc_loader_password.txt
# NIFI_ADMIN_PASSWORD_SOURCE_FILE=.secrets/nifi_admin_password.txt
# GRAFANA_ADMIN_PASSWORD_SOURCE_FILE=.secrets/grafana_admin_password.txt

# Optional: fetch runtime secrets from AWS Secrets Manager inside the Airflow
# container. The container resolves *_AWS_SECRET_ID after loading this file and
# can extract a JSON field with *_AWS_SECRET_FIELD.
# AIRFLOW__API__SECRET_KEY_AWS_SECRET_ID=olist/dev/airflow
# AIRFLOW__API__SECRET_KEY_AWS_SECRET_FIELD=api_secret_key
# REDSHIFT_PASSWORD_AWS_SECRET_ID=olist/dev/redshift
# REDSHIFT_PASSWORD_AWS_SECRET_FIELD=password
