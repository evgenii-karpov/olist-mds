  "version": 2,
  "panels": [
    {"id": 1, "type": "stat", "title": "Pipeline exporter", "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4}, "targets": [{"refId": "A", "expr": "olist_cdc_pipeline_up"}]},
    {"id": 2, "type": "stat", "title": "ClickHouse scrape", "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4}, "targets": [{"refId": "A", "expr": "up{job=\"clickhouse\"}"}]},
    {"id": 3, "type": "stat", "title": "ClickHouse uptime", "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"refId": "A", "expr": "ClickHouseAsyncMetrics_Uptime"}]},
    {"id": 4, "type": "stat", "title": "Transform failures", "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4}, "targets": [{"refId": "A", "expr": "olist_cdc_transform_failures_total"}]},
    {"id": 5, "type": "stat", "title": "Last ingest age", "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"refId": "A", "expr": "time() - olist_cdc_last_ingest_success_timestamp_seconds"}]},
    {"id": 6, "type": "stat", "title": "Last transform age", "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"refId": "A", "expr": "time() - olist_cdc_last_transform_success_timestamp_seconds"}]},
    {"id": 7, "type": "timeseries", "title": "ClickHouse queries", "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "targets": [{"refId": "A", "expr": "rate(ClickHouseProfileEvents_Query[5m])", "legendFormat": "queries"}, {"refId": "B", "expr": "rate(ClickHouseProfileEvents_FailedQuery[5m])", "legendFormat": "failed"}]},
    {"id": 8, "type": "timeseries", "title": "Raw CDC freshness", "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"refId": "A", "expr": "olist_cdc_raw_freshness_seconds", "legendFormat": "{{table}}"}]},
    {"id": 9, "type": "timeseries", "title": "Ingest and transform duration", "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"refId": "A", "expr": "olist_cdc_last_ingest_duration_seconds", "legendFormat": "ingest"}, {"refId": "B", "expr": "olist_cdc_last_transform_duration_seconds", "legendFormat": "transform"}]},
    {"id": 10, "type": "timeseries", "title": "Mart build age", "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [{"refId": "A", "expr": "time() - olist_cdc_mart_build_timestamp_seconds", "legendFormat": "{{table}}"}]}
  ]
