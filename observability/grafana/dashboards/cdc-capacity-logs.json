{
  "annotations": {"list": []}, "editable": false, "schemaVersion": 41,
  "tags": ["olist", "cdc", "phase-6", "capacity", "logs"],
  "templating": {"list": []}, "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser", "title": "Olist CDC — Capacity and Logs",
  "uid": "olist-cdc-capacity", "version": 1,
  "panels": [
    {"id": 1, "type": "stat", "title": "Host CPU busy", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "fieldConfig": {"defaults": {"unit": "percentunit"}}, "targets": [{"refId": "A", "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))"}]},
    {"id": 2, "type": "stat", "title": "Host memory used", "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}, "fieldConfig": {"defaults": {"unit": "percentunit"}}, "targets": [{"refId": "A", "expr": "1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes"}]},
    {"id": 3, "type": "stat", "title": "Max filesystem used", "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}, "fieldConfig": {"defaults": {"unit": "percentunit"}}, "targets": [{"refId": "A", "expr": "max(1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"})"}]},
    {"id": 4, "type": "stat", "title": "Running containers", "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "count(container_last_seen{name=~\"olist-.*\"})"}]},
    {"id": 5, "type": "timeseries", "title": "Container memory", "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"refId": "A", "expr": "container_memory_working_set_bytes{name=~\"olist-.*\"}", "legendFormat": "{{name}}"}]},
    {"id": 6, "type": "logs", "title": "Correlated service logs", "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "datasource": {"type": "loki", "uid": "loki"}, "targets": [{"refId": "A", "expr": "{environment=\"local\", service=~\"olist-.*\"}"}]}
  ]
}
