{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation", "s3:ListBucket", "s3:ListBucketVersions"],
      "Resource": ["arn:aws:s3:::olist-cdc"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:GetObjectVersion"],
      "Resource": [
        "arn:aws:s3:::olist-cdc/stage/*",
        "arn:aws:s3:::olist-cdc/manifests/*",
        "arn:aws:s3:::olist-cdc/landing/*"
      ]
    }
  ]
}
